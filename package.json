{
  "name": "beaconhq",
  "version": "0.4.0",
  "private": false,
  "type": "module",
  "description": "Beacon Node.js client SDK — buffer per-request telemetry and ship it to the Beacon ingest API. Includes Express, Fastify, Koa, NestJS, and Hono middleware, plus BullMQ cron/heartbeat monitoring.",
  "license": "MIT",
  "author": "Skyware LLC",
  "homepage": "https://beacon.skyware.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kb-gardner/beaconhq-js.git"
  },
  "bugs": {
    "url": "https://github.com/kb-gardner/beaconhq-js/issues"
  },
  "keywords": [
    "beacon",
    "observability",
    "monitoring",
    "telemetry",
    "apm",
    "api-monitoring",
    "express",
    "fastify",
    "koa",
    "nestjs",
    "hono",
    "middleware",
    "bullmq",
    "cron",
    "heartbeat"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bullmq": {
      "types": "./dist/bullmq.d.ts",
      "import": "./dist/bullmq.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "express": ">=4",
    "fastify": ">=4",
    "hono": ">=4",
    "koa": ">=2",
    "@koa/router": ">=10",
    "@nestjs/common": ">=9",
    "rxjs": ">=7",
    "bullmq": ">=5"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "fastify": { "optional": true },
    "hono": { "optional": true },
    "koa": { "optional": true },
    "@koa/router": { "optional": true },
    "@nestjs/common": { "optional": true },
    "rxjs": { "optional": true },
    "bullmq": { "optional": true }
  },
  "devDependencies": {
    "@koa/router": "^13.0.0",
    "@types/express": "^5.0.0",
    "@types/koa": "^2.15.0",
    "@types/koa__router": "^12.0.4",
    "@types/node": "^22.0.0",
    "bullmq": "^5.78.0",
    "express": "^5.1.0",
    "fastify": "^5.2.0",
    "hono": "^4.6.14",
    "koa": "^2.15.3",
    "rxjs": "^7.8.1",
    "typescript": "~6.0.2",
    "vitest": "^3.0.0",
    "zod": "^4.4.3"
  }
}
